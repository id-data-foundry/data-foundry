## OpenAPI/Swagger ROUTES ## 
## basic path:/api/v2/scripts ##

###
 #  summary: view a specific script
 #  parameters:
 #    - name: "id"
 #      in: "path"
 #      description: "Script id"
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #  responses:
 #    200:
 #      description: success
 #      schema:
 #        type: object
 #        properties:
 #          id:
 #            type: "integer"
 #            format: "int64"
 #          name:
 #            type: "string"
 #          description:
 #            type: "string"
 #          target:
 #            type: "string"
 #          description:
 #            type: "string"
 #          creationDate:
 #            type: "string"
 #          startDate:
 #            type: integer
 #            format: "int64"
 #          endDate:
 #            type: integer
 #            format: "int64"
 #          isOpenParticipation:
 #            type: boolean
 #          project_id:
 #            type: integer
 #            format: "int64"
 #    400:
 #      description: Not valid script.
 #    403:
 #      description: Not valid script, user, or api-token; or user can't access the script.
 ###
GET       /:id                            controllers.swagger.ScriptApiController.view(request: Request, id : Long)

###
 #  summary: add a new script
 #  parameters:
 #    - name: "id"
 #      in: "path"
 #      description: "Project id"
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #    - name: "body"
 #      in: "body"
 #      description: "add a new script"
 #      required: true
 #      schema:
 #        type: object
 #        required:
 #          - "script_name"
 #          - "description"
 #        properties:
 #          script_name:
 #            type: "string"
 #          description:
 #            type: "string"
 #  responses:
 #    200:
 #      description: success
 #      schema:
 #        type: object
 #        properties:
 #          id:
 #            description: "Id of the new script"
 #            type: integer
 #            format: "int64"
 #    400:
 #      description: Not valid user.
 #    403:
 #      description: User or api-token is not valid or user can't access the script.
 ###
POST      /add/:id                        controllers.swagger.ScriptApiController.add(request: Request, id : Long)

