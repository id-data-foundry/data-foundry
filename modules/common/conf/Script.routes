 #      in: "query"
 #      description: "Data for test script, no need to escape characters."
 #      required: true
 #      type: "string"
 #      example: "var data = {color: 123,position: 12.3};"
 #    - name: "code"
 #      in: "query"
 #      description: "Code content, no need to escape characters."
 #      type: "string"
 #      example: "DF.print(\"test message1 data: \" + data.color);DF.print(\"test message2 data: \" + data.color);"
 #      allowReserved: true
 #  responses:
 #    200:
 #      description: success
 #    400:
 #      description: Not valid user.
 #    403:
 #      description: User or api-token is not valid or user can't access the script.
 ###
GET       /execute/:id                    controllers.swagger.ScriptApiController.execute(request: Request, id : Long)

###
 #  summary: install code for a specific channel 
 #  parameters:
 #    - name: "id"
 #      in: "path"
 #      description: "Script id"
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #    - name: "channelName"
 #      in: "path"
 #      description: "Name of the channel to install the script"
 #      required: true
 #      type: "string"
 #  responses:
 #    200:
 #      description: success
 #    400:
 #      description: Not valid user.
 #    403:
 #      description: User or api-token is not valid or user can't access the script.
 ###
PUT       /install/:id/:channelName       controllers.swagger.ScriptApiController.install(request: Request, id : Long, channelName : String)

###
 #  summary: uninstall code for a specific channel 
 #  parameters:
 #    - name: "id"
 #      in: "path"
 #      description: "Script id"
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #  responses:
 #    200:
 #      description: success
 #    400:
 #      description: Not valid user.
 #    403:
 #      description: User or api-token is not valid or user can't access the script.
 ###
PUT       /uninstall/:id                  controllers.swagger.ScriptApiController.unInstall(request: Request, id : Long)

###
 #  summary: get all logs of a specific script 
