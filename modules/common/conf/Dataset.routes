###
 #  summary: download data from a dataset in CSV format
 #  parameters:
 #    - name: "id"
 #      in: "path"
 #      description: "Dataset id"
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #    - name: "participant_id"
 #      in: "query"
 #      description: "ID of participant to filter with"
 #      type: "integer"
 #      format: "int64"
 #    - name: "device_id"
 #      in: "query"
 #      description: "ID of device to filter with"
 #      type: "integer"
 #      format: "int64"
 #    - name: "wearable_id"
 #      in: "query"
 #      description: "ID of wearable to filter with"
 #      type: "integer"
 #      format: "int64"
 #    - name: "cluster_id"
 #      in: "query"
 #      description: "ID of cluster to filter with"
 #      type: "integer"
 #      format: "int64"
 #    - name: "limit"
 #      in: "query"
 #      description: "limit number of returned records"
 #      type: "integer"
 #      format: "int64"
 #    - name: "start"
 #      in: "query"
 #      description: "start timestamp (ms) of export interval"
 #      type: "integer"
 #      format: "int64"
 #    - name: "end"
 #      in: "query"
 #      description: "end timestamp (ms) of export interval"
 #      type: "integer"
 #      format: "int64"
 #  responses:
 #    200:
 #      description: success
 #    400:
 #      description: Not valid user.
 #    403:
 #      description: User or api-token is not valid or user can't access the dataset.
 ###
GET       /download/:id.csv               controllers.swagger.DatasetApiController.downloadCSV(request: Request, id : Long, participant_id : Long ?= -1, device_id : Long ?= -1, wearable_id: Long ?= -1, cluster_id : Long ?= -1, limit : Long ?= -1, start : Long ?= -1, end : Long ?= -1)

