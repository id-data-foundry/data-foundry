## OpenAPI/Swagger ROUTES ## 
## basic path:/api/v2/datasets ##

###
 #  summary: list all datasets of the user
 #  responses:
 #    200:
 #      description: success
 #  deprecated: true
 ###
GET       /                               controllers.swagger.DatasetApiController.datasets(request: Request)

###
 #  summary: view a specific dataset
 #  parameters:
 #    - name: "id"
 #      in: "path"
 #      description: "Dataset id"
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #  responses:
 #    200:
 #      description: success
 #      schema:
 #        type: object
 #        properties:
 #          id:
 #            type: "integer"
 #            format: "int64"
 #          title:
 #            type: "string"
 #          type:
 #            type: "string"
 #          target:
 #            type: "string"
 #          description:
 #            type: "string"
 #          keywords:
 #            type: "string"
 #          doi:
 #            type: "string"
 #          relation:
 #            type: "string"
 #          organization:
 #            type: "string"
 #          remarks:
 #            type: "string"
 #          license:
 #            type: "string"
 #          creationDate:
 #            type: "string"
 #          startDate:
 #            type: integer
 #            format: "int64"
 #          endDate:
 #            type: integer
 #            format: "int64"
 #          owner:
 #            type: "string"
 #          isOpenParticipation:
 #            type: boolean
 #          project_id:
 #            type: integer
 #            format: "int64"
 #          id:
 #            type: integer
 #            format: "int64"
 #          data:
 #            description: "information of files for Complete, Media, and Movement dataset"
 #            type: array
 #            items:
 #              ts:
 #                type: "string"
 #                description: "uploading date"
 #              name:
 #                type: "string"
 #              description:
 #                type: "string"
 #    400:
 #      description: Not valid dataset.
 #    403:
 #      description: Not valid dataset, user, or api-token; or user can't access the dataset.
 ###
GET       /$id<[0-9]+>                            controllers.swagger.DatasetApiController.dataset(request: Request, id : Long)

###
 #  summary: list all visible datasets
 #  responses:
 #    200:
 #      description: success
 #      schema:
 #        type: object
 #        properties:
 #          datasets:
 #            description: "Ids of datasets fit the condition"
 #            type: array
 #            items:
 #              type: integer
 #              format: "int64"
 ###
GET       /search                         controllers.swagger.DatasetApiController.searchDatasets(request: Request, filter : String ?= "", query : String ?= "", relation : String ?= "", organization : String ?= "")

###
 #  summary: search datasets with a specific dataset type and keywords
 #  parameters:
 #    - name: "filter"
 #      in: "path"
 #      description: "Choose the type of dataset."
 #      type: "string"
 #      enum: ["All dataset", "IoT", "Movement", "Survey", "Media"]
 #    - name: "query"
 #      in: "path"
 #      description: "Enter some keywords to search for"
 #      type: "string"
 #  responses:
 #    200:
 #      description: success
 #      schema:
 #        type: object
 #        properties:
 #          datsets:
 #            description: "Ids of datasets fit the condition"
 #            type: array
 #            items:
 #              type: integer
 #              format: "int64"
 ###
GET       /search/:filter/:query          controllers.swagger.DatasetApiController.searchDatasets(request: Request, filter : String, query : String, relation : String ?= "", organization : String ?= "")
GET       /search/                        controllers.swagger.DatasetApiController.searchDatasets(request: Request, filter : String ?= "", query : String ?= "", relation : String ?= "", organization : String ?= "")
GET       /search                         controllers.swagger.DatasetApiController.searchDatasets(request: Request, filter : String ?= "", query : String ?= "", relation : String ?= "", organization : String ?= "")

###
 #  summary: search datasets with a specific dataset type and keywords
 #  parameters:
 #    - name: "filter"
 #      in: "path"
 #      description: "Choose the type of dataset, enter some keywords to search for."
 #      type: "string"
 #      enum: ["All dataset", "IoT", "Movement", "Survey/Form", "Media"]
 #  responses:
 #    200:
 #      description: success
 #      schema:
 #        type: object
 #        properties:
 #          datasets:
 #            description: "Ids of datasets fit the condition"
 #            type: array
 #            items:
 #              type: integer
 #              format: "int64"
 ###
GET       /search/:filter                 controllers.swagger.DatasetApiController.searchDatasets(request: Request, filter : String, query : String ?= "", relation : String ?= "", organization : String ?= "")

