 ###
GET       /:id                      controllers.swagger.ProjectApiController.project(request: Request, id : Long)

###
 #  summary: retrieve labnotes of a project
 #  parameters:
 #    - name: "id"
 #      in: "path"
 #      description: "Retrieve labnotes of a specific project."
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #  responses:
 #    200:
 #      description: success
 #      schema:
 #        type: array
 #        items:
 #          type: object
 #          properties:
 #          type:
 #            type: "string"
 #          message:
 #            type: "string"
 #          source:
 #            type: "string"
 #          timestamp:
 #            type: "string"
 #    400:
 #      description: Not valid project.
 #    403:
 #      description: Not valid project, user, or api-token; or user can't access the project.
 ###
GET       /:id/labnotes                 controllers.swagger.ProjectApiController.labnotes(request: Request, id : Long)

###
 #  summary: add a new project
 #  parameters:
 #    - name: "body"
 #      in: "body"
 #      description: "Add a new project. Note that there is a maximum number of active projects per user on the platform (configurable). If this number if reached an error message will be returned."
 #      required: true
 #      schema:
 #        type: object
 #        required:
 #          - "name"
 #          - "intro"
 #          - "license"
 #        properties:
