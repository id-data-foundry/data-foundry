## OpenAPI/Swagger ROUTES ## 
## basic path:/api/v2/projects ##

###
 #  summary: list all projects that user has
 #  responses:
 #    200:
 #      description: success
 #      schema:
 #        type: object
 #        properties:
 #          ownProjects:
 #            description: "IDs of projects owned by the user"
 #            type: array
 #            items: 
 #              type: integer
 #              format: "int64"
 #          collaborations:
 #            description: "IDs of projects which the user has joined"
 #            type: array
 #            items: 
 #              type: integer
 #              format: "int64"
 #          subscriptions:
 #            description: "IDs of projects which the user has subscribed"
 #            type: array
 #            items: 
 #              type: integer
 #              format: "int64"
 #          archivedProjects:
 #            description: "IDs of archived projects owned by the user"
 #            type: array
 #            items: 
 #              type: integer
 #              format: "int64"
 #    400:
 #      description: No input.
 #    403:
 #      description: Not valid user or api-token.
 ###
GET       /                         controllers.swagger.ProjectApiController.projects(request: Request)

###
 #  summary: list all public projects
 #  responses:
 #    200:
 #      description: success
 #      schema:
 #        type: object
 #        properties:
 #          projects:
 #            description: "Id of projects"
 #            type: array
 #            items:
 #              type: integer
 #              format: "int64"
 ###
GET       /search                   controllers.swagger.ProjectApiController.searchProjects(request: Request, query : String ?= "")

###
 #  summary: search projects with keywords
 #  description: "Filter public projects with some keywords for the query."
 #  responses:
 #    200:
 #      description: success
 #      schema:
 #        type: object
 #        properties:
 #          projects:
 #            description: "Id of projects"
 #            type: array
 #            items:
 #              type: integer
 #              format: "int64"
 ###
GET       /search/:query            controllers.swagger.ProjectApiController.searchProjects(request: Request, query : String)

