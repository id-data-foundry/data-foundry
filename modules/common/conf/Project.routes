POST      /:id/edit                       controllers.swagger.ProjectApiController.edit(request: Request, id : Long)

###
 #  summary: archive an open project
 #  parameters:
 #    - name: "id"
 #      in: "path"
 #      description: "Archive an open project."
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #  responses:
 #    200:
 #      description: success
 #    400:
 #      description: Not valid user.
 #    403:
 #      description: User or api-token is not valid or user can't access the project.
 ###
POST      /:id/archive                      controllers.swagger.ProjectApiController.archive(request: Request, id : Long)

###
 #  summary: reopen an archived project
 #  parameters:
 #    - name: "id"
 #      in: "path"
 #      description: "Reopen an archived project."
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #  responses:
 #    200:
 #      description: success
 #    400:
 #      description: Not valid user.
 #    403:
 #      description: User or api-token is not valid or user can't access the project.
 ###
POST      /:id/reopen                      controllers.swagger.ProjectApiController.reopen(request: Request, id : Long)

###
 #  summary: subscribe to an project by a user
 #  description: Subscribe a specific project directly if it is shareable; if not, project owner will receive an email for the subscription, and it could be accepted by the owner with clicking the action link in the email.
 #  parameters:
 #    - name: "id"
 #      in: "path"
 #      description: "The id of the project to subscribe to."
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #  responses:
 #    200:
 #      description: success
 #      schema:
 #        type: object
 #        properties:
 #          id:
 #            description: "Id of the subscribed project will be returned if successful"
 #            type: integer
 #            format: "int64"
 #          
 #    400:
 #      description: Not valid user.
 #    403:
 #      description: User or api-token is not valid or user can't access the project.
 ###
POST      /:id/subscriptions           controllers.swagger.ProjectApiController.subscribe(request: Request, id : Long)

###
 #  summary: unsubscribe from a project by subscriber
 #  parameters:
 #    - name: "id"
 #      in: "path"
 #      description: "The id of the project to remove the subscription."
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #  responses:
 #    200:
 #      description: success
 #    400:
 #      description: Not valid user.
 #    403:
 #      description: User or api-token is not valid or user can't access the project.
 ###
DELETE    /:id/subscriptions        controllers.swagger.ProjectApiController.unsubscribe(request: Request, id : Long)

###
 #  summary: accept an application to subscribe to a project
 #  description: Accept an application to subscribe to a project directly if the project is shareable, or when the token from subscribe function and the also the user-token of the project owner is provided, then it can be accepted.
 #  parameters:
 #    - name: "id"
 #      in: "path"
 #      description: "The id of the project to remove the subscription."
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #    - name: "token"
 #      in: "path"
 #      description: "The token for the subscription."
 #      required: true
 #      type: "string"
 #  responses:
 #    200:
 #      description: success
 #  deprecated: true
 ###
POST      /:id/subscriptions/:token      controllers.swagger.ProjectApiController.addSubscription(request: Request, id : Long, token : String)

###
 #  summary: remove a subscriber from a project by its owner
 #  parameters:
 #    - name: "id"
 #      in: "path"
 #      description: "The id of the project to remove the subscription."
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #    - name: "subId"
 #      in: "path"
 #      description: "The id of the subscriber to be removed."
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #  responses:
 #    200:
 #      description: success
 #    400:
 #      description: Not valid user.
 #    403:
 #      description: User or api-token is not valid or user can't access the project.
 ###
DELETE    /:id/subscriptions/:subId   controllers.swagger.ProjectApiController.removeSubscription(request: Request, id : Long, subId : Long)

###
 #  summary: invite collaborator to an project by project owner by email
 #  parameters:
 #    - name: "id"
 #      in: "path"
 #      description: "The id of the project to invite the collaborator to join."
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #    - name: "email"
 #      in: "path"
 #      description: "The email of the collaborator to send invitation to."
 #      required: true
 #      type: "email"
 #  responses:
 #    200:
 #      description: success
 #    400:
 #      description: Not valid user.
 #    403:
 #      description: User or api-token is not valid or user can't access the project.
 ###
POST       /:id/collaborators/:email    controllers.swagger.ProjectApiController.inviteCollaborator(request: Request, id : Long, email : String)

###
 #  summary: remove a collaborator from a project by project owner
 #  parameters:
 #    - name: "id"
 #      in: "path"
 #      description: "The id of the project to remove the subscription."
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #    - name: "colId"
 #      in: "path"
 #      description: "The id of the collaborator to be removed."
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #  responses:
 #    200:
 #      description: success
 #    400:
 #      description: Not valid user.
 #    403:
 #      description: User or api-token is not valid or user can't access the project.
 ###
DELETE       /:id/collaborators/:colId   controllers.swagger.ProjectApiController.removeCollaborator(request: Request, id : Long, colId : Long)

###
 #  summary: accept an invitation to collaborate with the owner of the project
 #  parameters:
 #    - name: "id"
 #      in: "path"
 #      description: "The id of the project to join."
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #    - name: "token"
 #      in: "path"
 #      description: "The token for the invitation."
 #      required: true
 #      type: "string"
 #  responses:
 #    200:
 #      description: success
 #  deprecated: true
 ###
POST       /:id/collaborations/:token     controllers.swagger.ProjectApiController.addCollaboration(request: Request, id : Long, token : String)

###
 #  summary: cancel the collaboration of a project by collaborator
 #  parameters:
 #    - name: "id"
 #      in: "path"
 #      description: "The id of the project to remove the subscription."
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #  responses:
 #    200:
 #      description: success
 #    400:
 #      description: Not valid user.
 #    403:
 #      description: User or api-token is not valid or user can't access the project.
 ###
DELETE       /:id/collaborations         controllers.swagger.ProjectApiController.cancelCollaboration(request: Request, id : Long)

