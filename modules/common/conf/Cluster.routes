## OpenAPI/Swagger ROUTES ## 
## basic path:/api/v2/clusters ##

###
 #  summary: list all clusters of the user / researcher
 #  responses:
 #    200:
 #      description: success
 #  deprecated: true
 ###
GET       /                                       controllers.swagger.ClusterApiController.clusters(request: Request)

###
 #  summary: view a specific cluster
 #  parameters:
 #    - name: "id"
 #      in: "path"
 #      description: "Get information of a specific cluster."
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #  responses:
 #    200:
 #      description: success
 #      schema:
 #        type: object
 #        properties:
 #          id:
 #            description: "Id of wearable"
 #            type: integer
 #            format: "int64"
 #          name:
 #            type: string
 #          project:
 #            description: "Id of project"
 #            type: integer
 #            format: "int64"
 #          participants:
 #            description: "IDs of participants in this cluster"
 #            type: array
 #            items: 
 #              type: integer
 #              format: "int64"
 #          wearables:
 #            description: "IDs of wearables in this cluster"
 #            type: array
 #            items: 
 #              type: integer
 #              format: "int64"
 #          devices:
 #            description: "IDs of devices in this cluster"
 #            type: array
 #            items: 
 #              type: integer
 #              format: "int64"
 #    400:
 #      description: No input.
 #    403:
 #      description: Not valid user or mismatched password.
 ###
GET       /:id                                    controllers.swagger.ClusterApiController.cluster(request: Request, id : Long)

###
 #  summary: create a cluster 
 #  parameters:
 #    - in: "body"
 #      name: "body"
 #      description: "Necessary informations for adding a new cluster in the project."
 #      required: true
 #      schema:
 #        type: object
 #        required:
 #          - "name"
 #          - "project_id"
 #        properties:
 #          project_id:
 #            type: "integer"
 #            format: "int64"
 #          name:
 #            type: "string"
 #            description: "The name for the cluster."
 #  responses:
 #    200:
 #      description: success
 #      schema:
 #        type: object
 #        properties:
 #          id:
 #            description: "Id of the new cluster"
 #            type: integer
 #            format: "int64"
