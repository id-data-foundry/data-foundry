 #      description: Not valid user.
 #    403:
 #      description: User or api-token is not valid or user can't access this operation.
 ###
POST      /add                                     controllers.swagger.ClusterApiController.add(request: Request)

###
 #  summary: rename a specific cluster
 #  parameters:
 #    - name: "id"
 #      in: "path"
 #      description: "The id of the cluster to update information."
 #      required: true
 #      type: "integer"
 #      format: "int64"
 #    - name: "name"
 #      in: "path"
 #      description: "New name for the cluster."
 #      required: true
 #      type: "string"
 #  responses:
 #    200:
 #      description: success
 #      schema:
 #        type: object
 #        properties:
 #          id:
 #            description: "Id of the cluster"
 #            type: integer
 #            format: "int64"
 #    400:
 #      description: Not valid user.
 #    403:
 #      description: User or api-token is not valid or user can't access this operation.
 ###
GET      /rename/:id/:name                        controllers.swagger.ClusterApiController.rename(request: Request, id : Long, name: String)

###
 #  summary: delete a specific cluster
 #  parameters:
 #    - name: "id"
